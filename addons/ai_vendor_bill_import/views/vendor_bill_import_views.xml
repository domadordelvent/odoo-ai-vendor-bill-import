<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_ai_vendor_bill_import_tree" model="ir.ui.view">
        <field name="name">ai.vendor.bill.import.tree</field>
        <field name="model">ai.vendor.bill.import</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="vendor_name"/>
                <field name="invoice_number"/>
                <field name="invoice_date"/>
                <field name="total_amount"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_ai_vendor_bill_import_form" model="ir.ui.view">
        <field name="name">ai.vendor.bill.import.form</field>
        <field name="model">ai.vendor.bill.import</field>
        <field name="arch" type="xml">
            <form>

                <header>
                    <button name="action_mark_uploaded"
                            type="object"
                            string="Mark as Uploaded"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <field name="state" widget="statusbar"
                        statusbar_visible="draft,uploaded,processed,error"/>
                </header>

                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="pdf_file" filename="pdf_filename"/>
                        <field name="pdf_filename" invisible="1"/>
                        <field name="vendor_name"/>
                        <field name="invoice_number"/>
                        <field name="invoice_date"/>
                        <field name="total_amount"/>
                        <field name="state"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ai_vendor_bill_import" model="ir.actions.act_window">
        <field name="name">AI Vendor Bill Import</field>
        <field name="res_model">ai.vendor.bill.import</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_ai_vendor_bill_root"
            name="AI Vendor Bills"/>

    <menuitem id="menu_ai_vendor_bill_import"
            name="Imports"
            parent="menu_ai_vendor_bill_root"
            action="action_ai_vendor_bill_import"/>

</odoo>